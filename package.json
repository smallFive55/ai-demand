{
  "name": "ai-demand",
  "version": "0.1.0",
  "private": true,
  "description": "需求全流程管理系统 — AI 驱动的需求接待、分析、任务管理与复盘平台",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "format": "prettier --write \"**/*.{vue,ts,tsx,js,css,md,json,yaml}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "prettier": "^3.8.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@nestjs/core"]
  }
}
