# ====== 前端 (apps/web) ======
VITE_API_BASE_URL=/api
VITE_WECHAT_CORP_ID=
VITE_APP_TITLE=需求全流程管理系统

# ====== 后端 (apps/api) ======
PORT=8000

# 大模型（OpenAI 兼容）。不设 LLM_API_URL 时需求接待走本地 Echo 替身。
# 百炼等可只配 base：https://dashscope.aliyuncs.com/compatible-mode/v1（会自动补 /chat/completions）
# 或完整 URL：https://api.openai.com/v1/chat/completions
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
# LLM_COMPLETION_TIMEOUT_MS=60000
# LLM_ADMISSION_TIMEOUT_MS=15000

# 数据库 (MySQL 8.4)
# 与 apps/api 一致：可用 DB_USER / DB_NAME，或与下述 DB_USERNAME / DB_DATABASE 二选一（代码会兼容）
DB_HOST=localhost
DB_PORT=3306
DB_USER=
DB_NAME=
DB_USERNAME=
# 数据库密码：可明文，或使用 enc1: 密文（AES-256-GCM）。
# 使用密文时：DB_PASSWORD_SECRET 必须写在本文件（与 DB_PASSWORD 同级）；只在终端 set 无效。
# 生成密文（在 apps/api 下）：先 set DB_PASSWORD_SECRET=密钥（CMD 勿加引号）再 pnpm encrypt-db-password <明文>
DB_PASSWORD=
DB_PASSWORD_SECRET=
DB_DATABASE=ai_demand
# 与 apps/api 一致：API 启动时自动执行未完成迁移（接待需求表等）。若由运维单独跑迁移可设为 false
DB_MIGRATIONS_RUN=true

# Jest / 集成测试库（可选；不填则主机/端口/账号/密码跟随上方 DB_*，仅库名固定为 ai_demand_test）
# TEST_DB_HOST=
# TEST_DB_PORT=
# TEST_DB_USER=
# TEST_DB_PASSWORD=
# TEST_DB_NAME=ai_demand_test
# 为 true 时跳过 Jest globalSetup 清空测试库（调试脏数据场景）
# DISABLE_TEST_DB_RESET=

# Redis 8.x
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=7d

# 前端可访问的公网 Base URL（与前端访问地址一致，勿尾斜杠）。
# 同时用于：① 重置密码邮件链接；② 企业微信放弃通知深链。
# 向后兼容：未设置时回退到 APP_WEB_BASE_URL（Story 2.3 初版曾单独引入，后续版本可废弃）。
APP_PUBLIC_URL=http://localhost:5173
# APP_WEB_BASE_URL=
# 可选 SMTP；未配置时不发邮件。内网联调可将 AUTH_LOG_PASSWORD_RESET_TOKEN=true，在 API 日志中输出重置链接（勿用于生产）
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
AUTH_LOG_PASSWORD_RESET_TOKEN=false

# 初始化管理员（首次空库时写入 MySQL admin_auth_users 等表）
ADMIN_INIT_USERNAME=admin
ADMIN_INIT_PASSWORD=admin123456
ADMIN_INIT_DISPLAY_NAME=系统管理员

# ====== 企业微信放弃通知（Story 2.3）======
# 企业微信群机器人 Webhook URL（https 必填；仅在设置时才启用真实发送，否则静默 Noop）。
# 格式示例：https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=********
# ⚠️ URL 中 `?key=` 即发送凭证，请勿提交到 VCS。
WECOM_WEBHOOK_URL=
# 单次 HTTP 发送超时，默认 5000ms，范围 [1000, 30000]
# WECOM_HTTP_TIMEOUT_MS=5000

# 通知编排最大重试次数（含首次），默认 3，范围 [1, 8]
# NOTIFICATION_MAX_ATTEMPTS=3
# 指数退避基数（ms），默认 200，最小 10（生产保护）；测试可通过 mock 覆盖
# NOTIFICATION_BACKOFF_BASE_MS=200
# 应用优雅关闭时排空在飞通知的最长等待（ms），默认 5000，范围 [0, 30000]
# NOTIFICATION_SHUTDOWN_GRACE_MS=5000
# 放弃通知深链在前端的相对路径，默认 /business/approvals（对齐架构 architecture.md:104 契约）
# NOTIFICATION_ABANDON_DEEP_LINK_PATH=/business/approvals
