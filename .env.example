# ====== 前端 (apps/web) ======
VITE_API_BASE_URL=/api
VITE_WECHAT_CORP_ID=
VITE_APP_TITLE=需求全流程管理系统

# ====== 后端 (apps/api) ======
PORT=8000

# 大模型（OpenAI 兼容）。不设 LLM_API_URL 时需求接待走本地 Echo 替身。
# 百炼等可只配 base：https://dashscope.aliyuncs.com/compatible-mode/v1（会自动补 /chat/completions）
# 或完整 URL：https://api.openai.com/v1/chat/completions
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
# LLM_COMPLETION_TIMEOUT_MS=60000
# LLM_ADMISSION_TIMEOUT_MS=15000

# 数据库 (MySQL 8.4)
# 与 apps/api 一致：可用 DB_USER / DB_NAME，或与下述 DB_USERNAME / DB_DATABASE 二选一（代码会兼容）
DB_HOST=localhost
DB_PORT=3306
DB_USER=
DB_NAME=
DB_USERNAME=
# 数据库密码：可明文，或使用 enc1: 密文（AES-256-GCM）。
# 使用密文时：DB_PASSWORD_SECRET 必须写在本文件（与 DB_PASSWORD 同级）；只在终端 set 无效。
# 生成密文（在 apps/api 下）：先 set DB_PASSWORD_SECRET=密钥（CMD 勿加引号）再 pnpm encrypt-db-password <明文>
DB_PASSWORD=
DB_PASSWORD_SECRET=
DB_DATABASE=ai_demand
# 与 apps/api 一致：API 启动时自动执行未完成迁移（接待需求表等）。若由运维单独跑迁移可设为 false
DB_MIGRATIONS_RUN=true

# Jest / 集成测试库（可选；不填则主机/端口/账号/密码跟随上方 DB_*，仅库名固定为 ai_demand_test）
# TEST_DB_HOST=
# TEST_DB_PORT=
# TEST_DB_USER=
# TEST_DB_PASSWORD=
# TEST_DB_NAME=ai_demand_test
# 为 true 时跳过 Jest globalSetup 清空测试库（调试脏数据场景）
# DISABLE_TEST_DB_RESET=

# Redis 8.x
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=7d

# 忘记密码：邮件中的重置链接域名（与前端访问地址一致，勿尾斜杠）
APP_PUBLIC_URL=http://localhost:5173
# 可选 SMTP；未配置时不发邮件。内网联调可将 AUTH_LOG_PASSWORD_RESET_TOKEN=true，在 API 日志中输出重置链接（勿用于生产）
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
AUTH_LOG_PASSWORD_RESET_TOKEN=false

# 初始化管理员（首次空库时写入 MySQL admin_auth_users 等表）
ADMIN_INIT_USERNAME=admin
ADMIN_INIT_PASSWORD=admin123456
ADMIN_INIT_DISPLAY_NAME=系统管理员
