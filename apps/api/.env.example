# 服务端口
PORT=8000

# 数据库 (MySQL 8.4)
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=
DB_PASSWORD=
DB_DATABASE=ai_demand

# Redis 8.x
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=7d

# 初始化管理员（首次启动生效，写入 .runtime-data/admin-users.json）
ADMIN_INIT_USERNAME=admin
ADMIN_INIT_PASSWORD=admin123456
ADMIN_INIT_DISPLAY_NAME=系统管理员
