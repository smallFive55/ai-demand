# 生产 / 本地开发（MySQL）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=ai_demand
# 勿在生产开启；仅本地无迁移时可为 true
DB_SYNCHRONIZE=false
DB_LOGGING=false

PORT=8000
CORS_ORIGIN=http://localhost:5173

# 后台初始登录（首次空库时种子用户）
ADMIN_INIT_USERNAME=admin
ADMIN_INIT_PASSWORD=admin123456

# Jest 集成测试（默认与上类似，库名不同）
TEST_DB_HOST=127.0.0.1
TEST_DB_PORT=3306
TEST_DB_USER=root
TEST_DB_PASSWORD=
TEST_DB_NAME=ai_demand_test
