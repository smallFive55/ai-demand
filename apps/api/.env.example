# 生产 / 本地开发（MySQL）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
# 明文直接写；密文以 enc1: 开头，并设置 DB_PASSWORD_SECRET（与加密脚本相同密钥）
# pnpm encrypt-db-password <明文>（需先设置 DB_PASSWORD_SECRET）
DB_PASSWORD=
DB_PASSWORD_SECRET=
DB_NAME=ai_demand
# 勿在生产开启；仅本地无迁移时可为 true
DB_SYNCHRONIZE=false
# 启动时自动执行未完成迁移（默认开启）。若由 CI/运维单独跑 pnpm migration:run，可设为 false
DB_MIGRATIONS_RUN=true
DB_LOGGING=false

PORT=8000
CORS_ORIGIN=http://localhost:5173

# 大模型（OpenAI 兼容 Chat Completions）。不设 LLM_API_URL 时接待对话走本地 Echo 替身。
# 可填完整地址，或只填 base（如阿里云百炼）：https://dashscope.aliyuncs.com/compatible-mode/v1
# 代码会自动补 /chat/completions；也可直接写 …/v1/chat/completions。
# OpenAI 官方示例：https://api.openai.com/v1/chat/completions
LLM_API_URL=
LLM_API_KEY=
# 请求体里的 model 字段；默认 gpt-4o-mini
LLM_MODEL=gpt-4o-mini
# 单轮对话补全 HTTP 超时（毫秒），默认 10000；百炼/公网较慢可改为 60000～120000
# LLM_COMPLETION_TIMEOUT_MS=60000
# 准入打分单独请求超时（毫秒），默认 4000
# LLM_ADMISSION_TIMEOUT_MS=15000

# 后台初始登录（首次空库时种子用户）
ADMIN_INIT_USERNAME=admin
ADMIN_INIT_PASSWORD=admin123456

# Jest 集成测试（可选；留空则主机/端口/账号/密码继承上方 DB_*，仅库名用 TEST_DB_NAME）
# TEST_DB_HOST=
# TEST_DB_PORT=
# TEST_DB_USER=
# TEST_DB_PASSWORD=
TEST_DB_NAME=ai_demand_test
