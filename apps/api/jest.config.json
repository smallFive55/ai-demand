{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "maxWorkers": 1,
  "testRegex": ".*\\.spec\\.ts$",
  "transform": {
    "^.+\\.ts$": "ts-jest"
  },
  "collectCoverageFrom": ["src/**/*.ts", "!src/main.ts"],
  "coverageDirectory": "./coverage",
  "testEnvironment": "node",
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/src/$1"
  }
}
